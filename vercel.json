{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "functions": {
    "main.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/review",
      "dest": "/main.py"
    },
    {
      "src": "/review-repo",
      "dest": "/main.py"
    },
    {
      "src": "/download-repo",
      "dest": "/main.py"
    }
  ]
}
