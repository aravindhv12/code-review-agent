{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/review$",
      "dest": "/main.py"
    },
    {
      "src": "^/review-repo$",
      "dest": "/main.py"
    },
    {
      "src": "^/download-repo$",
      "dest": "/main.py"
    }
  ]
}
